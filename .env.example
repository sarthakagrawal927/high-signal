# --- Auth (Cloudflare Access — Zero Trust) ---
# Admin paths (/review, /api/admin/*) sit behind a self-hosted CF Access app.
# IdP (Google) + allow-list policy are configured in the CF Zero Trust dashboard.
# These two values come from the Access application; no shared secret needed.
CF_ACCESS_AUD=
CF_ACCESS_TEAM_DOMAIN=
# Optional extra allow-list checked in code (comma-separated emails). Leave
# empty to defer entirely to the CF Access policy.
ADMIN_ALLOWED_EMAILS=

# --- AI provider (swappable baseURL pattern) ---
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# --- Cloudflare ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
D1_DATABASE_ID=
VECTORIZE_INDEX_NAME=

# --- Ingestion sources ---
SEC_USER_AGENT=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
X_BEARER_TOKEN=
NEWS_API_KEY=

# --- App ---
NODE_ENV=development

# --- SaaS Maker ---
NEXT_PUBLIC_SAASMAKER_API_KEY=

# --- PostHog (@saas-maker/posthog-client) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
