# --- Auth (Clerk) ---
# Create a Clerk app, then copy these from the Clerk Dashboard API keys page.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional extra admin allow-list checked by /api/admin/* (comma-separated emails).
# Leave empty to allow any signed-in Clerk user through app-side admin routes.
ADMIN_ALLOWED_EMAILS=

# --- AI provider (swappable baseURL pattern) ---
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# --- Cloudflare ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
D1_DATABASE_ID=
VECTORIZE_INDEX_NAME=

# --- Ingestion sources ---
SEC_USER_AGENT=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
X_BEARER_TOKEN=
NEWS_API_KEY=

# --- App ---
NODE_ENV=development

# --- SaaS Maker ---
NEXT_PUBLIC_SAASMAKER_API_KEY=

# --- PostHog (@saas-maker/posthog-client) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
